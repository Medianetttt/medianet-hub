{
  "version": 2,
  "name": "medianet-agency-hub",
  "routes": [
    { "src": "/api/fic(.*)", "dest": "/api/fic.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,X-Fic-Token,X-Company-Id" }
      ]
    }
  ]
}
